# ============================================
# Servidor
# ============================================
PORT=3000

# URL base pública de la API (usada en la documentación de Swagger)
# En local: http://localhost:3000
# En producción: https://tu-app.up.railway.app  (o Render/Fly.io)
API_BASE_URL=http://localhost:3000

# ============================================
# Base de datos PostgreSQL
# ============================================
# Opción A: usar una sola cadena de conexión (recomendado en Railway/Render)
DATABASE_URL=postgresql://usuario:password@host:5432/restaurante

# Opción B: variables separadas (usadas solo si DATABASE_URL no está definida)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=restaurante

# Poner en "true" si el proveedor de base de datos requiere SSL (Railway, Render, etc.)
DB_SSL=false

# ============================================
# JWT
# ============================================
# Usa una cadena larga y aleatoria en producción, nunca la de este ejemplo.
JWT_SECRET=cambia_esta_clave_por_una_muy_larga_y_secreta
JWT_EXPIRES_IN=2h
